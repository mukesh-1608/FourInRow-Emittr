name: 04 DAST Scanning
on: [push, pull_request]

jobs:
  dast-scan:
    runs-on: ubuntu-latest
    permissions:
      issues: write # Allows ZAP to report findings to your Issues tab
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Build and Start Staging
        run: |
          docker compose up -d
          docker build -t fourinrow-app .
          docker run -d -p 5000:5000 -e KAFKA_BROKER=localhost:9092 --network host fourinrow-app
          sleep 45

      - name: Grant Workspace Permissions
        run: chmod 777 $GITHUB_WORKSPACE

      - name: Run OWASP ZAP Baseline Scan
        uses: zaproxy/action-baseline@v0.10.0
        with:
          target: 'http://localhost:5000'
          fail_action: false
